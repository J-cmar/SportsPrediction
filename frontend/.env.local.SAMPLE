# ===========================================
# GitHub OAuth Configuration (REQUIRED)
# ===========================================
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Set Authorization callback URL to: http://localhost:3000/api/auth/callback/github
# For production, add: http://your-domain.com/api/auth/callback/github

AUTH_GITHUB_ID="your_github_oauth_app_client_id"
AUTH_GITHUB_SECRET="your_github_oauth_app_secret"

# ===========================================
# NextAuth Configuration (REQUIRED)
# ===========================================
# AUTH_SECRET: Run 'npx auth secret' to generate a random secret
# Or use: openssl rand -base64 32

AUTH_SECRET="your_generated_secret_here"
AUTH_TRUST_HOST="true"

# NEXTAUTH_URL: Your application's base URL
# For local development:
NEXTAUTH_URL="http://localhost:3000"
# For production:
NEXTAUTH_URL="http://your-domain.com"

# ===========================================
# AWS DynamoDB Configuration (OPTIONAL)
# ===========================================
# Leave these commented out for local development (uses JWT sessions)
# Uncomment and fill in for production deployment with persistent sessions

# AUTH_DYNAMODB_ID="your_aws_access_key_id"
# AUTH_DYNAMODB_SECRET="your_aws_secret_access_key"
# AUTH_DYNAMODB_REGION="us-east-1"

# ===========================================
# Backend API Configuration (OPTIONAL)
# ===========================================
# Only needed if your Django backend is running on a different host/port
# Default: http://localhost:8000

# NEXT_PUBLIC_API_URL="http://localhost:8000"
